{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://your.local/schemas/insurance_request_v1.json",
  "title": "AL Insurance Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request",
    "customer",
    "lease",
    "insurance",
    "insured_objects"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "alliance.insurance_request.v1"
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_number",
        "submission_date",
        "applicant_type",
        "application_format"
      ],
      "properties": {
        "request_number": {
          "type": "string",
          "minLength": 1,
          "description": "Номер заявки/ДФА в системе заказчика."
        },
        "submission_date": {
          "type": "string",
          "format": "date"
        },
        "source_system": {
          "type": [
            "string",
            "null"
          ]
        },
        "applicant_type": {
          "type": "string",
          "enum": [
            "legal_entity",
            "individual_entrepreneur"
          ]
        },
        "application_format": {
          "type": "string",
          "enum": [
            "casco_equipment",
            "property"
          ]
        },
        "branch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            }
          }
        },
        "manager": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "full_name": {
              "type": "string"
            }
          }
        }
      }
    },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "inn"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "legal_entity",
            "individual_entrepreneur"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "inn": {
          "type": "string",
          "pattern": "^([0-9]{10}|[0-9]{12})$"
        },
        "birth_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "legal_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "postal_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "business_activity": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_start_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "contract_end_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "creditor_bank": {
          "type": [
            "string",
            "null"
          ]
        },
        "insured_party": {
          "type": "string",
          "enum": [
            "lessor",
            "lessee",
            "both",
            "unknown"
          ]
        }
      }
    },
    "insurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product",
        "period",
        "franchise",
        "premium_payment"
      ],
      "properties": {
        "product": {
          "type": "string",
          "enum": [
            "casco",
            "equipment",
            "property",
            "other"
          ]
        },
        "period": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "one_year",
                "full_lease",
                "custom"
              ]
            },
            "text": {
              "type": [
                "string",
                "null"
              ]
            },
            "start_date": {
              "type": [
                "string",
                "null"
              ],
              "format": "date"
            },
            "end_date": {
              "type": [
                "string",
                "null"
              ],
              "format": "date"
            },
            "months": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            }
          }
        },
        "territory": {
          "type": [
            "string",
            "null"
          ]
        },
        "coverage_terms": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "insured_sum_type": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "aggregate",
                "non_aggregate",
                null
              ]
            },
            "indemnity_basis": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "with_depreciation",
                "without_depreciation",
                null
              ]
            },
            "guard_conditions": {
              "type": [
                "string",
                "null"
              ]
            },
            "property_location_right_holder": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "lessee_owner",
                "third_party_owner",
                "unknown",
                null
              ],
              "description": "Для страхования имущества: правообладатель места расположения оборудования."
            },
            "property_location_right_holder_text": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "franchise": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "options"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "none",
                "with_franchise",
                "both_variants"
              ]
            },
            "options": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/franchise_option"
              }
            }
          }
        },
        "premium_payment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "single",
                "installment",
                "unknown"
              ]
            },
            "frequency": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "quarterly",
                "semiannual",
                "annual",
                "custom",
                null
              ]
            },
            "comment": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "insured_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/insured_object"
      }
    },
    "underwriting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "usage_purposes": {
          "type": [
            "string",
            "null"
          ]
        },
        "autostart": {
          "type": "boolean"
        },
        "casco_category_ce": {
          "type": "boolean"
        },
        "transportation": {
          "type": "boolean"
        },
        "construction_work": {
          "type": "boolean"
        },
        "key_completeness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "keys_count": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "text": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "title_document": {
          "type": [
            "string",
            "null"
          ]
        },
        "telematics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean"
            },
            "complex_name": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "anti_theft_systems": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "alarm": {
              "$ref": "#/$defs/security_item"
            },
            "immobilizer": {
              "$ref": "#/$defs/security_item"
            },
            "mechanical_devices": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "satellite_system": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "required": {
                  "type": "boolean"
                },
                "brand": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "model": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "configuration": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          }
        },
        "additional_coverages": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "transportation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "required": {
                  "type": "boolean"
                },
                "origin": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "destination": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "estimated_days": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                }
              }
            },
            "construction_work": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "required": {
                  "type": "boolean"
                },
                "description": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "currency"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "franchise_option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "none",
            "percent",
            "absolute"
          ]
        },
        "percent": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "amount": {
          "anyOf": [
            {
              "$ref": "#/$defs/money"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "security_item": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "factory": {
          "type": "boolean"
        },
        "additional": {
          "type": "boolean"
        },
        "name_or_model": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "insured_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_no",
        "object_type",
        "description",
        "acquisition_cost"
      ],
      "properties": {
        "item_no": {
          "type": "integer",
          "minimum": 1
        },
        "object_type": {
          "type": "string",
          "enum": [
            "vehicle",
            "special_equipment",
            "equipment",
            "property",
            "other"
          ]
        },
        "category": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "brand": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "vin": {
          "type": [
            "string",
            "null"
          ]
        },
        "serial_number": {
          "type": [
            "string",
            "null"
          ]
        },
        "manufacturing_year": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1900,
          "maximum": 2100
        },
        "condition": {
          "type": "string",
          "enum": [
            "new",
            "used",
            "unknown"
          ]
        },
        "equipment_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "power_or_capacity": {
          "type": [
            "string",
            "null"
          ]
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "acquisition_cost": {
          "$ref": "#/$defs/money"
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
